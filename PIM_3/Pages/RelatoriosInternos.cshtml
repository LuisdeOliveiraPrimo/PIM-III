@page
@model PIM_3.Pages.RelatoriosInternosModel
@{
    ViewData["Title"] = "Central de Auditoria | Stoque.me";
}

<div id="app-root"></div>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const root = document.getElementById('app-root');

        // add responsive viewport meta
        const meta = document.createElement('meta');
        meta.name = 'viewport';
        meta.content = 'width=device-width, initial-scale=1';
        document.head.appendChild(meta);

        const style = document.createElement('style');
        style.innerHTML = `
            body { margin: 0; background: #f0f4f3; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; }
            .sidebar { width: 250px; background: #045951; height: 100vh; position: fixed; color: white; padding: 30px 20px; z-index: 100; }
            .sidebar h2 { font-style: italic; font-weight: 800; margin-bottom: 50px; color: #0ABFAD; }
            .nav-link { display: block; color: rgba(255,255,255,0.7); text-decoration: none; padding: 15px; border-radius: 10px; margin-bottom: 10px; transition: 0.3s; }
            .nav-link:hover, .nav-link.active { background: #0ABFAD; color: white; }
            
            .content { margin-left: 290px; padding: 40px; }
            .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }

            /* Filtros */
            .filter-bar { background: white; padding: 20px; border-radius: 15px; display: flex; gap: 20px; margin-bottom: 30px; box-shadow: 0 4px 10px rgba(0,0,0,0.02); }
            .filter-group { display: flex; flex-direction: column; gap: 5px; }
            .filter-group label { font-size: 0.7rem; font-weight: bold; color: #888; text-transform: uppercase; }
            .filter-group select, .filter-group input { padding: 8px; border: 1px solid #eee; border-radius: 8px; outline: none; color: #444; }

            /* Grid de Relatórios */
            .report-section { display: grid; grid-template-columns: 1fr; gap: 20px; }
            .report-card { 
                background: white; 
                padding: 20px; 
                border-radius: 15px; 
                display: flex; 
                align-items: center; 
                gap: 20px; 
                box-shadow: 0 5px 15px rgba(0,0,0,0.02);
                transition: 0.3s;
                border: 1px solid transparent;
            }
            .report-card:hover { border-color: #0ABFAD; transform: translateX(5px); }
            .icon-box { width: 50px; height: 50px; border-radius: 12px; background: #e0f2f1; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
            
            .report-info { flex: 1; }
            .report-info h4 { margin: 0; color: #045951; }
            .report-info p { margin: 5px 0 0; color: #888; font-size: 0.85rem; }

            .btn-download { 
                background: #0ABFAD; 
                color: white; 
                border: none; 
                padding: 10px 20px; 
                border-radius: 8px; 
                cursor: pointer; 
                font-weight: bold; 
                font-size: 0.8rem;
                display: inline-flex;
                align-items: center;
                gap: 8px;
                text-decoration: none;
            }
            .btn-download:hover { background: #045951; }

            /* Log de Atividade */
            .log-panel { background: white; padding: 25px; border-radius: 20px; margin-top: 40px; }
            .log-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
            .log-table th { text-align: left; padding: 12px; color: #888; border-bottom: 1px solid #eee; }
            .log-table td { padding: 12px; border-bottom: 1px solid #f9f9f9; color: #444; }
            .badge { padding: 4px 8px; border-radius: 5px; font-size: 0.7rem; font-weight: bold; }
            .bg-pdf { background: #ffe3e3; color: #e03131; }
            .bg-xls { background: #e3faf3; color: #099268; }

            .menu-toggle { display: none; position: fixed; top: 12px; left: 12px; z-index: 400; border: none; background: linear-gradient(180deg,#0ABFAD,#07a08f); color: #fff; padding: 8px; border-radius: 10px; font-size: 1.1rem; box-shadow: 0 6px 18px rgba(10,191,173,0.18); transition: transform .18s ease, box-shadow .18s ease; }
            .menu-toggle:active { transform: scale(.98); }
            .overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 350; opacity: 0; transition: opacity .22s ease; pointer-events: none; }

            /* Responsive adjustments */
            @@media (max-width: 900px) {
                .menu-toggle { display: block; }
                .sidebar { position: fixed; left: 0; top: 0; bottom: 0; width: 280px; max-width: 86%; height: 100vh; transform: translateX(-115%); transition: transform .20s cubic-bezier(.2,.9,.2,1); padding: 20px; z-index: 380; box-shadow: 8px 0 30px rgba(3,58,51,0.12); }
                .sidebar h2 { margin-bottom: 20px; }
                .nav-link { display: block; padding: 12px 10px; }
                .content { margin-left: 0; padding: 20px; }
                .filter-bar { flex-direction: column; gap: 12px; }
                .header-flex { flex-direction: column; align-items: flex-start; gap: 12px; }
                .report-card { flex-direction: column; align-items: flex-start; }
                .icon-box { width: 48px; height: 48px; }
                .btn-download { width: 100%; justify-content: center; }
                .overlay { display: block; }
                .overlay.show { opacity: 1; pointer-events: auto; }
                .sidebar-open .overlay { opacity: 1; pointer-events: auto; }
                .sidebar-open .sidebar { transform: translateX(0); }
            }

            @@media (max-width: 480px) {
                .filter-group label { font-size: 0.65rem; }
                .report-info p { font-size: 0.8rem; }
                .header-flex h1 { font-size: 1.25rem; }
                .report-card { padding: 16px; }
                .btn-download { padding: 10px; font-size: 0.9rem; }
            }
        `;
        document.head.appendChild(style);

        root.innerHTML = `
            <button id="menuToggle" class="menu-toggle" aria-label="Abrir menu" aria-expanded="false">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="3" y="6" width="18" height="2" rx="1" fill="white"></rect>
                    <rect x="3" y="11" width="18" height="2" rx="1" fill="white"></rect>
                    <rect x="3" y="16" width="18" height="2" rx="1" fill="white"></rect>
                </svg>
            </button>
            <div id="overlay" class="overlay"></div>
            <div class="sidebar">
                <h2>Stoque.me</h2>
                <a href="/HomeInterna" class="nav-link">🏠 Início</a>
                <a href="/DashboardInterno" class="nav-link">📊 Dashboard</a>
                <a href="/Estoque" class="nav-link">📦 Estoque</a>
                <a href="/RelatoriosInternos" class="nav-link active">📑 Relatórios</a>
                <div style="margin-top: 100px;">
                    <a href="/" class="nav-link" style="color: #ff7675;">🚪 Sair</a>
                </div>
            </div>

            <div class="content">
                <div class="header-flex">
                    <h1 style="color: #045951; margin:0;">Centro de Resultados Internos</h1>
                    <span style="color: #888; font-size: 0.9rem;">Luis (Admin) • Unidade Matriz</span>
                </div>

                <div class="filter-bar">
                    <div class="filter-group">
                        <label>Categoria</label>
                        <select>
                            <option>Todos os Relatórios</option>
                            <option>Financeiro</option>
                            <option>Estoque / PVPS</option>
                            <option>Suprimentos</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Período</label>
                        <input type="month" value="2026-03">
                    </div>
                    <div class="filter-group">
                        <label>Formato</label>
                        <select>
                            <option>PDF (Documento)</option>
                            <option>XLSX (Planilha)</option>
                            <option>CSV (Dados)</option>
                        </select>
                    </div>
                </div>

                <div class="report-section">
                    <div class="report-card">
                        <div class="icon-box">💰</div>
                        <div class="report-info">
                            <h4>Fechamento Mensal Consolidado</h4>
                            <p>DRE completa, Fluxo de Caixa e Margem de Contribuição por setor.</p>
                        </div>
                        <a class="btn-download" href="?handler=Download&reportId=fechamento&format=pdf">⬇️ Download PDF</a>
                    </div>

                    <div class="report-card">
                        <div class="icon-box">🛡️</div>
                        <div class="report-info">
                            <h4>Impacto Estratégico PVPS (Desperdício Zero)</h4>
                            <p>Detalhamento de R$ 118.240,00 recuperados em produtos próximos ao vencimento.</p>
                        </div>
                        <a class="btn-download" href="?handler=Download&reportId=impacto&format=pdf">⬇️ Download PDF</a>
                    </div>

                    <div class="report-card">
                        <div class="icon-box">🚛</div>
                        <div class="report-info">
                            <h4>Auditoria de Fornecedores e Supply Chain</h4>
                            <p>Score de performance de 7.000 parceiros e análise de lead time.</p>
                        </div>
                        <a class="btn-download" href="?handler=Download&reportId=fornecedores&format=xlsx">⬇️ Download XLSX</a>
                    </div>

                    <div class="report-card">
                        <div class="icon-box">👥</div>
                        <div class="report-info">
                            <h4>Performance da Equipe e Operação</h4>
                            <p>Produtividade por colaborador, erros de bipagem e tempo médio de fila.</p>
                        </div>
                        <a class="btn-download" href="?handler=Download&reportId=equipe&format=pdf">⬇️ Download PDF</a>
                    </div>

                    <div class="report-card">
                        <div class="icon-box">🔍</div>
                        <div class="report-info">
                            <h4>Inventário Geral (15.240 SKUs)</h4>
                            <p>Lista completa de itens, posição de gôndola e valor de custo imobilizado.</p>
                        </div>
                        <a class="btn-download" href="?handler=Download&reportId=inventario&format=csv">⬇️ Download CSV</a>
                    </div>
                </div>

                <div class="log-panel">
                    <h3 style="color: #045951; margin-bottom: 20px;">📜 Histórico de Geração (Log)</h3>
                    <table class="log-table">
                        <thead>
                            <tr>
                                <th>Data/Hora</th>
                                <th>Relatório</th>
                                <th>Usuário</th>
                                <th>Formato</th>
                       <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>23/03/2026 14:05</td>
                                <td>Impacto PVPS - Março</td>
                                <td>Luis (Admin)</td>
                                <td><span class="badge bg-pdf">PDF</span></td>
                                <td style="color: #2ecc71;">● Concluído</td>
                            </tr>
                            <tr>
                                <td>23/03/2026 09:12</td>
                                <td>Inventário Geral</td>
                                <td>Luis (Admin)</td>
                                <td><span class="badge bg-xls">XLSX</span></td>
                                <td style="color: #2ecc71;">● Concluído</td>
                            </tr>
                            <tr>
                                <td>22/03/2026 18:30</td>
                                <td>Fechamento Mensal</td>
                                <td>Sistema (Auto)</td>
                                <td><span class="badge bg-pdf">PDF</span></td>
                                <td style="color: #2ecc71;">● Concluído</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        `;

        // sidebar toggle handlers for small screens (accessibility + focus management)
        const menuToggleBtn = document.getElementById('menuToggle');
        const overlayEl = document.getElementById('overlay');
        if (menuToggleBtn && overlayEl) {
            const escHandler = (e) => { if (e.key === 'Escape') setOpen(false); };
            function setOpen(open) {
                document.body.classList.toggle('sidebar-open', open);
                menuToggleBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
                if (open) {
                    overlayEl.classList.add('show');
                    const first = document.querySelector('.sidebar .nav-link');
                    if (first) first.focus();
                    document.addEventListener('keydown', escHandler);
                } else {
                    overlayEl.classList.remove('show');
                    menuToggleBtn.focus();
                    document.removeEventListener('keydown', escHandler);
                }
            }

            menuToggleBtn.addEventListener('click', () => setOpen(!document.body.classList.contains('sidebar-open')));
            overlayEl.addEventListener('click', () => setOpen(false));
            document.querySelectorAll('.nav-link').forEach(n => n.addEventListener('click', () => setOpen(false)));
        }
    });
</script>