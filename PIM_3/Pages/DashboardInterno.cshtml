@page
@model PIM_3.Pages.DashboardInternoModel
@{
    ViewData["Title"] = "BI Analítico Master | Stoque.me";
}

<div id="app-root"></div>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const root = document.getElementById('app-root');

        const style = document.createElement('style');
        style.innerHTML = `
            body { margin: 0; background: #f0f4f3; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; }
            .sidebar { width: 250px; background: #045951; height: 100vh; position: fixed; color: white; padding: 30px 20px; z-index: 100; }
            .sidebar h2 { font-style: italic; font-weight: 800; margin-bottom: 50px; color: #0ABFAD; }
            .nav-link { display: block; color: rgba(255,255,255,0.7); text-decoration: none; padding: 15px; border-radius: 10px; margin-bottom: 10px; transition: 0.3s; }
            .nav-link:hover, .nav-link.active { background: #0ABFAD; color: white; }
            
            .content { margin-left: 290px; padding: 40px; }
            .section-header { margin-bottom: 40px; border-left: 5px solid #0ABFAD; padding-left: 15px; }
            .group-title { color: #045951; font-size: 1.1rem; font-weight: 800; text-transform: uppercase; margin: 40px 0 20px; letter-spacing: 1px; display: flex; align-items: center; gap: 10px; }

            /* Grid de 3 Cards */
            .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 25px; }
            .stat-card { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-top: 4px solid #0ABFAD; transition: 0.3s; }
            .stat-card:hover { transform: translateY(-5px); }
            .stat-card small { color: #888; font-weight: bold; font-size: 0.75rem; text-transform: uppercase; }
            .stat-card h2 { margin: 10px 0; color: #333; font-size: 1.8rem; }
            .trend { font-size: 0.8rem; font-weight: bold; }
            .up { color: #2ecc71; } .down { color: #e74c3c; }

            /* Grid de 4 Visualizações */
            .charts-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px; }
            .viz-card { background: white; padding: 20px; border-radius: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.02); min-height: 280px; display: flex; flex-direction: column; }
            .viz-card h3 { margin: 0 0 10px; color: #045951; font-size: 0.9rem; border-bottom: 1px solid #f0f0f0; padding-bottom: 10px; }
            .viz-card p { color: #777; font-size: 0.75rem; line-height: 1.4; margin-top: auto; padding-top: 10px; text-align: center; }

            /* Gráfico de Barras */
            .bar-container { display: flex; align-items: flex-end; height: 120px; gap: 8px; margin: 15px 0; }
            .bar { flex: 1; background: #0ABFAD; border-radius: 3px; position: relative; transition: 0.5s; cursor: pointer; }
            .bar:hover { background: #045951; }
            .bar::after { content: attr(data-val); position: absolute; top: -20px; left: 50%; transform: translateX(-50%); font-size: 0.65rem; font-weight: bold; opacity: 0; transition: 0.3s; }
            .bar:hover::after { opacity: 1; }

            /* Gráfico de Linha (ROI) */
            .line-chart-svg { width: 100%; height: 100px; margin-top: 20px; }
            .line-path { fill: none; stroke: #0ABFAD; stroke-width: 3; stroke-linecap: round; stroke-dasharray: 500; stroke-dashoffset: 500; animation: draw 2s forwards ease-in-out; }
            .line-point { fill: #045951; stroke: white; stroke-width: 2; }
            @@keyframes draw { 
                to { stroke-dashoffset: 0; } 
            }

            /* Pizza/Rosca */
            .donut-viz-group { display: flex; flex-direction: column; align-items: center; margin-top: 15px; flex-grow: 1; justify-content: center; }
            .donut-box { width: 100px; height: 100px; border-radius: 50%; position: relative; }
            .donut-box::before { content: ""; position: absolute; width: 70px; height: 70px; background: white; border-radius: 50%; top: 15px; left: 15px; }
            .donut-legend { width: 100%; font-size: 0.7rem; color: #666; margin-top: 15px; list-style: none; padding: 0; }
            .donut-legend li { display: flex; justify-content: space-between; margin-bottom: 4px; padding: 2px 0; border-bottom: 1px solid #f9f9f9; }

            .progress-line { height: 10px; background: #eee; border-radius: 10px; overflow: hidden; margin: 10px 0; }
            .progress-fill { height: 100%; background: #0ABFAD; transition: 1.5s; }
            .table-mini { width: 100%; font-size: 0.8rem; border-collapse: collapse; }
            .table-mini td { padding: 8px 0; border-bottom: 1px solid #f9f9f9; }
        `;
        document.head.appendChild(style);

        root.innerHTML = `
            <div class="sidebar">
                <h2>Stoque.me</h2>
                <a href="/HomeInterna" class="nav-link">🏠 Início</a>
                <a href="/DashboardInterno" class="nav-link active">📊 Dashboard</a>
                <a href="/Estoque" class="nav-link">📦 Estoque</a>
                <a href="/RelatoriosInternos" class="nav-link">📑 Relatórios</a>
                <div style="margin-top: 100px;">
                    <a href="/" class="nav-link" style="color: #ff7675;">🚪 Sair</a>
                </div>
            </div>

            <div class="content">
                <div class="section-header">
                    <h1 style="color: #045951; margin:0;">BI Analítico Master - Unidade Matriz</h1>
                    <p style="color: #888;">Gestão de 15.000 SKUs em tempo real | Total Faturado: R$ 1.84M</p>
                </div>

                <div class="group-title">💰 Performance Financeira</div>
                <div class="stats-grid">
                    <div class="stat-card">
                        <small>Faturamento Bruto Mensal</small>
                        <h2>R$ 1.842.508</h2>
                        <span class="trend up">▲ 14.2% (Meta Batida)</span>
                    </div>
                    <div class="stat-card">
                        <small>Ticket Médio Geral</small>
                        <h2>R$ 124,50</h2>
                        <span class="trend up">▲ 8.1% (Impacto PVPS)</span>
                    </div>
                    <div class="stat-card">
                        <small>Lucro Líquido Projetado</small>
                        <h2>R$ 452.210</h2>
                        <span class="trend up">▲ Eficiência Operacional</span>
                    </div>
                </div>
                <div class="charts-grid">
                    <div class="viz-card">
                        <h3>Faturamento 7 Dias</h3>
                        <div class="bar-container">
                            <div class="bar" style="height:60%" data-val="R$ 250k"></div>
                            <div class="bar" style="height:80%" data-val="R$ 310k"></div>
                            <div class="bar" style="height:100%; background:#045951" data-val="R$ 420k"></div>
                            <div class="bar" style="height:40%" data-val="R$ 180k"></div>
                        </div>
                        <p>Destaque para o pico de vendas no 5º dia útil.</p>
                    </div>
                    <div class="viz-card">
                        <h3>Novos Clientes</h3>
                        <div class="bar-container">
                            <div class="bar" style="height:40%"></div>
                            <div class="bar" style="height:55%"></div>
                            <div class="bar" style="height:75%"></div>
                            <div class="bar" style="height:90%"></div>
                        </div>
                        <p>Taxa de fidelização orgânica mensal.</p>
                    </div>
                    <div class="viz-card">
                        <h3>Margem por Setor</h3>
                        <div class="donut-viz-group">
                            <div class="donut-box" style="background: conic-gradient(#0ABFAD 0% 15%, #045951 15% 40%, #ffc107 40% 100%);"></div>
                            <ul class="donut-legend">
                                <li><span><b style="color:#0ABFAD">●</b> Bebidas (15%)</span> <b>R$ 276k</b></li>
                                <li><span><b style="color:#045951">●</b> Mercearia (25%)</span> <b>R$ 460k</b></li>
                                <li><span><b style="color:#ffc107">●</b> Hortifruti (60%)</span> <b>R$ 1.1M</b></li>
                            </ul>
                        </div>
                    </div>
                    <div class="viz-card">
                        <h3>ROI Tecnológico (Tendência)</h3>
                        <div style="flex-grow:1; display:flex; flex-direction:column; justify-content:center;">
                            <svg class="line-chart-svg" viewBox="0 0 200 100">
                                <path class="line-path" d="M10,80 L50,70 L90,40 L130,50 L170,20" />
                                <circle class="line-point" cx="10" cy="80" r="4" />
                                <circle class="line-point" cx="50" cy="70" r="4" />
                                <circle class="line-point" cx="90" cy="40" r="4" />
                                <circle class="line-point" cx="130" cy="50" r="4" />
                                <circle class="line-point" cx="170" cy="20" r="4" />
                            </svg>
                            <div style="display:flex; justify-content:space-between; font-size:0.6rem; color:#999; padding:0 10px;">
                                <span>JAN</span><span>FEV</span><span>MAR</span><span>ABR</span><span>MAI</span>
                            </div>
                        </div>
                        <p>Crescimento de <b>32.4%</b> na eficiência global.</p>
                    </div>
                </div>

                <div class="group-title">📦 Inventário e Logística (15.000 Produtos)</div>
                <div class="stats-grid">
                    <div class="stat-card" style="border-top-color:#f39c12">
                        <small>Total de SKUs Ativos</small>
                        <h2>15.240</h2>
                        <span class="trend">98% com movimentação</span>
                    </div>
                    <div class="stat-card" style="border-top-color:#f39c12">
                        <small>Valor Total em Estoque</small>
                        <h2>R$ 4.210.840</h2>
                        <span class="trend">Custo de Imobilizado</span>
                    </div>
                    <div class="stat-card" style="border-top-color:#f39c12">
                        <small>Alertas Críticos de Validade</small>
                        <h2 style="color:#e74c3c">1.142</h2>
                        <span class="trend down">Ação PVPS Necessária</span>
                    </div>
                </div>
                <div class="charts-grid">
                    <div class="viz-card">
                        <h3>Top 3 Giro</h3>
                        <table class="table-mini">
                            <tr><td>Cerveja Skol 269ml</td><td align="right"><b>12k un</b></td></tr>
                            <tr><td>Leite Integral 1L</td><td align="right"><b>8k un</b></td></tr>
                            <tr><td>Arroz T1 5kg</td><td align="right"><b>4k un</b></td></tr>
                        </table>
                    </div>
                    <div class="viz-card">
                        <h3>Ruptura de Gôndola</h3>
                        <div class="bar-container">
                            <div class="bar" style="height:15%; background:#e74c3c" data-val="Falta"></div>
                            <div class="bar" style="height:10%; background:#e74c3c" data-val="Crítico"></div>
                        </div>
                        <p>Perda de venda por falta física.</p>
                    </div>
                    <div class="viz-card">
                        <h3>Giro por Vencimento</h3>
                        <div class="donut-viz-group">
                            <div class="donut-box" style="background: conic-gradient(#f39c12 0% 60%, #e67e22 60% 100%);"></div>
                            <ul class="donut-legend">
                                <li><span><b style="color:#f39c12">●</b> Risco Baixo (60%)</span> <b>9.1k itens</b></li>
                                <li><span><b style="color:#e67e22">●</b> Risco Alto (40%)</span> <b>6.1k itens</b></li>
                            </ul>
                        </div>
                    </div>
                    <div class="viz-card">
                        <h3>Acuracidade</h3>
                        <h2 style="color:#f39c12; text-align:center; margin-top:20px;">99.1%</h2>
                        <p>Diferença Sistema vs Prateleira.</p>
                    </div>
                </div>

                <div class="group-title">📈 Resultados do Liquidificador PVPS</div>
                <div class="stats-grid">
                    <div class="stat-card" style="border-top-color:#045951">
                        <small>Capital Salvo este Mês</small>
                        <h2 style="color:#0ABFAD">R$ 118.240</h2>
                        <span class="trend up">▲ Conversão de Risco</span>
                    </div>
                    <div class="stat-card" style="border-top-color:#045951">
                        <small>Crescimento MoM (Mês/Mês)</small>
                        <h2>+18.4%</h2>
                        <span class="trend up">Expansão de Faturamento</span>
                    </div>
                    <div class="stat-card" style="border-top-color:#045951">
                        <small>Taxa de Quebra (Perda Total)</small>
                        <h2 style="color:#2ecc71">0.42%</h2>
                        <span class="trend">Benchmark Global: 1.5%</span>
                    </div>
                </div>
                <div class="charts-grid">
                    <div class="viz-card">
                        <h3>Eficiência do Algoritmo</h3>
                        <div class="efficiency-mini" style="background: #f9f9f9; padding: 10px; border-radius: 10px; margin-top:15px;">
                            <div style="display:flex; justify-content:space-between"><span>Conversão</span><b>92%</b></div>
                            <div class="progress-line"><div class="progress-fill" style="width:92%"></div></div>
                        </div>
                    </div>
                    <div class="viz-card">
                        <h3>Vendas por Horário</h3>
                        <div class="bar-group">
                            <div class="bar" style="height:30%"></div>
                            <div class="bar" style="height:100%"></div>
                            <div class="bar" style="height:60%"></div>
                        </div>
                        <p>Picos de fluxo operacional.</p>
                    </div>
                    <div class="viz-card">
                        <h3>Custo de Descarte</h3>
                        <div class="donut-viz-group">
                            <div class="donut-box" style="background: conic-gradient(#888 0% 10%, #045951 10% 100%);"></div>
                            <ul class="donut-legend">
                                <li><span><b style="color:#888">●</b> Descarte (10%)</span> <b>R$ 1.2k</b></li>
                                <li><span><b style="color:#045951">●</b> Salvo PVPS (90%)</span> <b>R$ 10.8k</b></li>
                            </ul>
                        </div>
                    </div>
                    <div class="viz-card">
                        <h3>NPS de Gestão</h3>
                        <h2 style="color:#045951; text-align:center; margin-top:20px;">9.4 / 10</h2>
                        <p>Satisfação com a ferramenta.</p>
                    </div>
                </div>

                <div class="group-title">🚛 Cadeia de Suprimentos (7.000 Fornecedores)</div>
                <div class="stats-grid">
                    <div class="stat-card" style="border-top-color:#6741d9">
                        <small>Parceiros Homologados</small>
                        <h2>7.142</h2>
                        <span class="trend">Base Ativa 2026</span>
                    </div>
                    <div class="stat-card" style="border-top-color:#6741d9">
                        <small>Lead Time Médio</small>
                        <h2>3.2 Dias</h2>
                        <span class="trend down">▼ 18% no tempo de espera</span>
                    </div>
                    <div class="stat-card" style="border-top-color:#6741d9">
                        <small>Saving em Compras</small>
                        <h2 style="color:#2ecc71">R$ 64.300</h2>
                        <span class="trend">Negociação por Volume</span>
                    </div>
                </div>
                <div class="charts-grid">
                    <div class="viz-card">
                        <h3>Qualidade de Entrega</h3>
                        <div class="bar-container">
                            <div class="bar" style="height:90%; background:#0ABFAD" data-val="90% No Prazo"></div>
                            <div class="bar" style="height:10%; background:#e74c3c" data-val="10% Atraso"></div>
                        </div>
                        <p>Performance logística da malha.</p>
                    </div>
                    <div class="viz-card">
                        <h3>Concentração de Preço</h3>
                        <div class="donut-viz-group">
                            <div class="donut-box" style="background: conic-gradient(#6741d9 0% 70%, #045951 70% 100%);"></div>
                            <ul class="donut-legend">
                                <li><span><b style="color:#6741d9">●</b> Competitivo (70%)</span> <b>5k fornec.</b></li>
                                <li><span><b style="color:#045951">●</b> Premium (30%)</span> <b>2k fornec.</b></li>
                            </ul>
                        </div>
                    </div>
                    <div class="viz-card">
                        <h3>Score de Performance</h3>
                        <table class="table-mini">
                            <tr><td><b>Ambev</b></td><td align="right"><span style="color:#2ecc71">9.8</span></td></tr>
                            <tr><td><b>Nestlé</b></td><td align="right"><span style="color:#2ecc71">9.4</span></td></tr>
                            <tr><td><b>Unilever</b></td><td align="right"><span style="color:#f1c40f">8.9</span></td></tr>
                        </table>
