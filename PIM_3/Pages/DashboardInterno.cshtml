                    </div>
                    <div class="viz-card">
                        <h3>Pedidos Inbound</h3>
                        <h2 style="color:#6741d9; text-align:center; margin-top:20px;">142</h2>
                        <p>Cargas confirmadas em trânsito.</p>
                    </div>
                </div>
            </div>
        `;
    });
</script>