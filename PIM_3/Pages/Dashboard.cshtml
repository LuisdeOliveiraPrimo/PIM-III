@page
@model PIM_3.Pages.DashboardModel
@{
    ViewData["Title"] = "Inteligência de Negócio";
}

<div id="app-root"></div>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const root = document.getElementById('app-root');

        // Estilos CSS rápidos para os gráficos
        const style = document.createElement('style');
        style.innerHTML = `
            .dash-row { display: flex; align-items: center; gap: 50px; margin-bottom: 80px; padding: 40px; background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); }
            .dash-row.reverse { flex-direction: row-reverse; }
            .graph-box { flex: 1; display: flex; justify-content: center; align-items: center; min-height: 250px; }
            .text-box { flex: 1; }
            .text-box h3 { color: #045951; font-size: 1.8rem; margin-bottom: 15px; }
            .text-box p { color: #666; line-height: 1.6; font-size: 1.1rem; }
            .bar { background: #0ABFAD; border-radius: 5px 5px 0 0; transition: 0.3s; cursor: pointer; }
            .bar:hover { background: #045951; }
        `;
        document.head.appendChild(style);

        root.innerHTML = `
            <div style="padding: 40px 80px; background: #fdfdfd; min-height: 100vh; font-family: 'Segoe UI', sans-serif;">
                
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 50px;">
                    <div>
                        <h1 style="color: #222; margin: 0; font-weight: 800;">Dashboard Estratégico</h1>
                        <p style="color: #888;">A inteligência analítica que transforma movimentações em lucro real.</p>
                    </div>
                    <button onclick="window.location.href='/'" style="padding: 12px 25px; cursor: pointer; border: 2px solid #0ABFAD; color: #0ABFAD; background: transparent; border-radius: 30px; font-weight: bold;">← Painel Principal</button>
                </div>

                <div class="dash-row">
                    <div class="graph-box">
                        <div style="display: flex; align-items: flex-end; height: 200px; gap: 15px; width: 100%;">
                            <div class="bar" style="height: 40%; width: 14%;"></div>
                            <div class="bar" style="height: 60%; width: 14%;"></div>
                            <div class="bar" style="height: 85%; width: 14%;"></div>
                            <div class="bar" style="height: 55%; width: 14%;"></div>
                            <div class="bar" style="height: 95%; width: 14%; background: #045951;"></div>
                            <div class="bar" style="height: 70%; width: 14%;"></div>
                        </div>
                    </div>
                    <div class="text-box">
                        <h3>Faturamento vs. ROI</h3>
                        <p>Este gráfico de barras monitora o desempenho financeiro diário. Ele é crucial para o dono do mercado identificar os <b>picos de venda</b>. No Stoque.me, cruzamos esses dados com o preço de custo para mostrar o lucro real, não apenas o faturamento bruto.</p>
                    </div>
                </div>

                <div class="dash-row reverse">
                    <div class="graph-box">
                        <div style="width: 220px; height: 220px; border-radius: 50%; background: conic-gradient(#0ABFAD 0% 40%, #045951 40% 70%, #ffc107 70% 90%, #eee 90% 100%); position: relative;">
                            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 100px; height: 100px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: #444;">Vendas</div>
                        </div>
                    </div>
                    <div class="text-box">
                        <h3>Mix de Produtos (Giro)</h3>
                        <p>O gráfico de rosca exibe quais categorias dominam o estoque. É útil para o <b>planejamento de compras</b>: se a categoria de Bebidas representa 40% das vendas, o sistema sugere um maior investimento nesse setor para evitar faltas.</p>
                    </div>
                </div>

                <div class="dash-row">
                    <div class="graph-box">
                         <div style="width: 100%; height: 150px; background: #f0fdfc; border-radius: 10px; position: relative; overflow: hidden; border: 1px solid #0ABFAD;">
                            <div style="position: absolute; bottom: 0; left: 0; width: 100%; height: 60%; background: linear-gradient(0deg, #0ABFAD 0%, transparent 100%); opacity: 0.3;"></div>
                            <div style="position: absolute; top: 20%; left: 10%; width: 80%; height: 2px; background: #0ABFAD; box-shadow: 0 0 10px #0ABFAD;"></div>
                         </div>
                    </div>
                    <div class="text-box">
                        <h3>Prevenção de Perdas</h3>
                        <p>Este indicador de área mostra a eficácia do seu <b>Botão de Promoção</b>. A linha azul representa o dinheiro recuperado através de liquidações automáticas sugeridas pelo Stoque.me em produtos próximos ao vencimento.</p>
                    </div>
                </div>

                <div class="dash-row reverse">
                    <div class="graph-box">
                        <div style="display: flex; flex-direction: column; gap: 15px; width: 80%;">
                            <div style="width: 100%; background: #eee; height: 20px; border-radius: 10px; overflow: hidden;"><div style="width: 90%; background: #0ABFAD; height: 100%;"></div></div>
                            <div style="width: 100%; background: #eee; height: 20px; border-radius: 10px; overflow: hidden;"><div style="width: 75%; background: #0ABFAD; height: 100%;"></div></div>
                            <div style="width: 100%; background: #eee; height: 20px; border-radius: 10px; overflow: hidden;"><div style="width: 40%; background: #045951; height: 100%;"></div></div>
                        </div>
                    </div>
                    <div class="text-box">
                        <h3>Performance da Equipe</h3>
                        <p>Monitoramos a produtividade através do módulo de <b>Gestão de Operação</b>. Este gráfico identifica quem mais realiza baixas de vendas e reposições, facilitando feedbacks baseados em dados reais.</p>
                    </div>
                </div>

                <div class="dash-row">
                    <div class="graph-box">
                        <div style="display: flex; align-items: flex-end; height: 180px; gap: 8px; width: 100%; border-left: 2px solid #eee; padding-left: 10px;">
                            <div style="flex: 1; background: #eee; height: 20%;"></div>
                            <div style="flex: 1; background: #eee; height: 35%;"></div>
                            <div style="flex: 1; background: #0ABFAD; height: 70%;"></div>
                            <div style="flex: 1; background: #0ABFAD; height: 50%;"></div>
                            <div style="flex: 1; background: #0ABFAD; height: 60%;"></div>
                            <div style="flex: 1; background: #045951; height: 95%;"></div>
                            <div style="flex: 1; background: #045951; height: 85%;"></div>
                        </div>
                    </div>
                    <div class="text-box">
                        <h3>Fluxo por Horário</h3>
                        <p>Identifica os <b>momentos críticos</b> de atendimento. Com isso, o gestor planeja escalas de funcionários e reabastecimento de gôndolas sem comprometer a agilidade dos caixas nos horários de pico.</p>
                    </div>
                </div>

                <div class="dash-row reverse">
                    <div class="graph-box">
                        <div style="width: 100%; display: flex; flex-direction: column; gap: 20px;">
                            <div style="display: flex; justify-content: space-between; font-size: 0.9rem;"><span>Disponibilidade</span><span style="color: #28a745; font-weight: bold;">94%</span></div>
                            <div style="width: 100%; background: #eee; height: 15px; border-radius: 10px; overflow: hidden;"><div style="width: 94%; background: #0ABFAD; height: 100%;"></div></div>
                            <div style="display: flex; justify-content: space-between; font-size: 0.9rem;"><span>Ruptura (Falta)</span><span style="color: #dc3545; font-weight: bold;">6%</span></div>
                            <div style="width: 100%; background: #eee; height: 15px; border-radius: 10px; overflow: hidden;"><div style="width: 6%; background: #dc3545; height: 100%;"></div></div>
                        </div>
                    </div>
                    <div class="text-box">
                        <h3>Índice de Ruptura</h3>
                        <p>Mede a saúde do inventário. O Stoque.me visa manter a ruptura abaixo de 5% através de <b>alertas preventivos</b>, garantindo que o cliente sempre encontre o que procura nas prateleiras.</p>
                    </div>
                </div>

            </div>
        `;
    });
</script>