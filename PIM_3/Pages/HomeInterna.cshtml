@page
@model PIM_3.Pages.HomeInternaModel
@{
    ViewData["Title"] = "Torre de Controle | Stoque.me";
}

<div id="app-root"></div>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const root = document.getElementById('app-root');

        const style = document.createElement('style');
        style.innerHTML = `
            body { margin: 0; background: #f0f4f3; font-family: 'Segoe UI', sans-serif; overflow-x: hidden; }
            .sidebar { width: 250px; background: #045951; height: 100vh; position: fixed; color: white; padding: 30px 20px; z-index: 100; }
            .sidebar h2 { font-style: italic; font-weight: 800; margin-bottom: 50px; color: #0ABFAD; }
            .nav-link { display: block; color: rgba(255,255,255,0.7); text-decoration: none; padding: 15px; border-radius: 10px; margin-bottom: 10px; transition: 0.3s; }
            .nav-link:hover, .nav-link.active { background: #0ABFAD; color: white; }
            
            .content { margin-left: 290px; padding: 40px; }

            /* Top Bar Status */
            .system-status { display: flex; gap: 20px; margin-bottom: 20px; font-size: 0.7rem; color: #666; background: white; padding: 12px 25px; border-radius: 12px; box-shadow: 0 2px 5px rgba(0,0,0,0.02); align-items: center; }
            .dot { height: 8px; width: 8px; border-radius: 50%; display: inline-block; background: #2ecc71; animation: pulse 2s infinite; }
            @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }

            /* Welcome Banner */
            .welcome-banner { 
                background: linear-gradient(135deg, #045951, #0ABFAD); 
                color: white; padding: 30px; border-radius: 25px; margin-bottom: 30px; 
                display: flex; justify-content: space-between; align-items: center;
                box-shadow: 0 10px 30px rgba(10, 191, 173, 0.2);
            }

            /* Grid Layout Ultra */
            .ultra-grid { display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: 20px; }
            .panel { background: white; padding: 20px; border-radius: 20px; box-shadow: 0 5px 20px rgba(0,0,0,0.02); margin-bottom: 20px; }
            .panel h3 { margin-top: 0; color: #045951; font-size: 0.95rem; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid #f0f0f0; padding-bottom: 12px; margin-bottom: 15px; }

            /* Atalhos */
            .quick-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 30px; }
            .action-card { background: white; padding: 20px; border-radius: 15px; text-align: center; cursor: pointer; transition: 0.3s; border: 1px solid transparent; }
            .action-card:hover { transform: translateY(-5px); border-color: #0ABFAD; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
            .action-icon { font-size: 2rem; margin-bottom: 10px; display: block; }

            /* Sensores e Pulso */
            .sensor-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
            .sensor-card { background: #f8f9fa; padding: 12px; border-radius: 12px; border-left: 4px solid #0ABFAD; }
            .sensor-card small { font-size: 0.6rem; color: #888; text-transform: uppercase; }
            .sensor-card b { display: block; font-size: 1rem; color: #333; }

            /* Alertas e Linhas */
            .item-row { display: flex; align-items: center; gap: 10px; padding: 12px; border-radius: 12px; margin-bottom: 8px; background: #f8f9fa; font-size: 0.8rem; }
            .item-row.critical { background: #fff5f5; border-left: 4px solid #ff7675; }
            .btn-action { background: #0ABFAD; color: white; border: none; padding: 6px 12px; border-radius: 6px; font-size: 0.65rem; cursor: pointer; margin-left: auto; font-weight: bold; }

            /* Status Bars */
            .progress-container { height: 8px; background: #eee; border-radius: 10px; margin: 8px 0; overflow: hidden; }
            .progress-fill { height: 100%; background: #045951; }

            .badge { padding: 4px 8px; border-radius: 6px; font-size: 0.6rem; font-weight: bold; }
            .badge-live { background: #e7f5ff; color: #228be6; }
        `;
        document.head.appendChild(style);

        root.innerHTML = `
            <div class="sidebar">
                <h2>Stoque.me</h2>
                <a href="/HomeInterna" class="nav-link active">🏠 Início</a>
                <a href="/DashboardInterno" class="nav-link">📊 Dashboard</a>
                <a href="/Estoque" class="nav-link">📦 Estoque</a>
                <a href="/RelatoriosInternos" class="nav-link">📑 Relatórios</a>
                <div style="margin-top: 100px;">
                    <a href="/" class="nav-link" style="color: #ff7675;">🚪 Sair</a>
                </div>
            </div>

            <div class="content">
                <div class="system-status">
                    <span><span class="dot"></span> Database: <b>SQLite Cluster Online</b></span>
                    <span>📦 <b>15.240</b> SKUs Mapeados</span>
                    <span>📡 IoT: <b>42 Sensores Ativos</b></span>
                    <span style="margin-left:auto">🏢 Unidade: <b>Matriz São Paulo</b></span>
                </div>

                <div class="welcome-banner">
                    <div>
                        <h1 style="margin:0; font-size: 1.8rem;">Olá, Luis! 👋</h1>
                        <p style="margin:5px 0 0; opacity:0.9;">O algoritmo PVPS processou <b>1.142 alertas</b>. R$ 118k recuperados.</p>
                    </div>
                    <div style="text-align:right">
                        <small>VOLUME VENDAS MARÇO</small>
                        <h2 style="margin:0;">R$ 1.84M</h2>
                    </div>
                </div>

                <div class="quick-actions">
                    <div class="action-card" onclick="window.location.href='/DashboardInterno'">
                        <span class="action-icon">📈</span>
                        <h3>Analisar BI</h3>
                        <p style="font-size:0.7rem; color:#888;">Performance e ROI</p>
                    </div>
                    <div class="action-card" onclick="window.location.href='/Estoque'">
                        <span class="action-icon">🔍</span>
                        <h3>Auditoria</h3>
                        <p style="font-size:0.7rem; color:#888;">Conferência de 15k SKUs</p>
                    </div>
                    <div class="action-card" onclick="window.location.href='/RelatoriosInternos'">
                        <span class="action-icon">📑</span>
                        <h3>Relatórios</h3>
                        <p style="font-size:0.7rem; color:#888;">Exportar DRE e Auditoria</p>
                    </div>
                </div>

                <div class="ultra-grid">
                    <div class="col">
                        <div class="panel">
                            <h3>🚨 Ações Prioritárias (PVPS)</h3>
                            <div class="item-row critical">
                                <div><b>Iogurte Grego #882</b><br><small>Vencimento em 24h (54 un)</small></div>
                                <button class="btn-action">Ativar 40%</button>
                            </div>
                            <div class="item-row critical">
                                <div><b>Ruptura: Tomate X</b><br><small>Estoque crítico (02 un)</small></div>
                                <button class="btn-action" style="background:#e74c3c">Pedir</button>
                            </div>
                            <div class="item-row" style="background:#fff9db; border-left:4px solid #fcc419">
                                <div><b>Padaria #441</b><br><small>Vencimento em 48h</small></div>
                                <button class="btn-action" style="background:#f39c12">Promoção</button>
                            </div>
                        </div>

                        <div class="panel">
                            <h3>❄️ Cadeia de Frio (IoT)</h3>
                            <div class="sensor-grid">
                                <div class="sensor-card"><small>Câmara 01</small><b>-18.4°C</b></div>
                                <div class="sensor-card" style="border-left-color:#e74c3c"><small>Ilha Congel.</small><b>-12.1°C ⚠️</b></div>
                                <div class="sensor-card"><small>Laticínios</small><b>4.2°C</b></div>
                                <div class="sensor-card"><small>Açougue</small><b>2.1°C</b></div>
                            </div>
                        </div>

                        <div class="panel">
                            <h3>👥 Gestão de Equipe</h3>
                            <div class="item-row"><span>Operadores de Caixa</span><b style="margin-left:auto">12 Ativos</b></div>
                            <div class="item-row"><span>Repositores (Gôndola)</span><b style="margin-left:auto">08 Ativos</b></div>
                            <div class="item-row"><span>Prevenção de Perdas</span><b style="margin-left:auto">03 Ativos</b></div>
                        </div>
                    </div>

                    <div class="col">
                        <div class="panel">
                            <h3>🚚 Inbound (Doca/Pátio)</h3>
                            <div class="item-row">
                                <span class="badge badge-live">DOCA 1</span>
                                <b>Ambev (450 grades)</b>
                                <span style="margin-left:auto; color:#2ecc71">●</span>
                            </div>
                            <div class="item-row">
                                <span class="badge" style="background:#eee">DOCA 2</span>
                                <b>Nestlé (Agendado 15h)</b>
                            </div>
                            <div class="item-row">
                                <span class="badge" style="background:#eee">DOCA 3</span>
                                <b>Hortifruti Regional</b>
                            </div>
                        </div>

                        <div class="panel">
                            <h3>📅 Agenda Fornecedores</h3>
                            <div class="item-row"><span>Coca-Cola</span><small style="margin-left:auto">10:00h - OK</small></div>
                            <div class="item-row"><span>Unilever</span><small style="margin-left:auto">16:45h - Pendente</small></div>
                        </div>

                        <div class="panel">
                            <h3>🎯 IA: Previsão de Demanda</h3>
                            <div class="item-row" style="background:#e7f5ff; border-left:4px solid #339af0">
                                <div><b>Cervejas: +15% Amanhã</b><br><small>Motivo: Previsão Calor 32°C</small></div>
                            </div>
                        </div>
                    </div>

                    <div class="col">
                        <div class="panel">
                            <h3>⏱️ Pulso Real-time</h3>
                            <div class="sensor-grid">
                                <div class="sensor-card"><small>Clientes Loja</small><b>142</b></div>
                                <div class="sensor-card"><small>Fila Média</small><b>3.5 min</b></div>
                                <div class="sensor-card"><small>Ticket Médio</small><b>R$ 112</b></div>
                                <div class="sensor-card"><small>Checkouts</small><b>08/10</b></div>
                            </div>
                        </div>

                        <div class="panel">
                            <h3>💎 Fidelidade App</h3>
                            <div class="item-row"><span>Check-ins agora</span><b style="margin-left:auto; color:#0ABFAD">42</b></div>
                            <div class="item-row"><span>Cupons hoje</span><b style="margin-left:auto">128</b></div>
                        </div>

                        <div class="panel">
                            <h3>📦 Status do Inventário</h3>
                            <small>Ocupação Total (15k SKUs)</small>
                            <div class="progress-container"><div class="progress-fill" style="width: 84%;"></div></div>
                            <div style="display:flex; justify-content:space-between; font-size:0.7rem; color:#666;">
                                <span>84.2% Ocupado</span>
                                <b>15.8% Livre</b>
                            </div>
                        </div>

                        <div class="panel">
                            <h3>📈 Atividade do Dia</h3>
                            <div style="font-size:0.8rem;">
                                <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                                    <span>Vendas Sessão</span><b>R$ 54.120</b>
                                </div>
                                <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                                    <span>Itens Bipados</span><b>4.512</b>
                                </div>
                                <div style="display:flex; justify-content:space-between;">
                                    <span>ROI PVPS Hoje</span><b style="color:#2ecc71">R$ 3.840</b>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        `;
    });
</script>